# Local development profile. Static credentials and restricted local ws:// are permitted only outside production.
OPENSOCKET_ENVIRONMENT=development
OPENSOCKET_GATEWAY_URL=ws://host.docker.internal:18080/ws/agents
OPENSOCKET_AGENT_ID=openclaw-agent-local-001
OPENSOCKET_AGENT_CREDENTIAL_MODE=static
OPENSOCKET_AGENT_TOKEN=dev-token-change-me
OPENSOCKET_AGENT_CREDENTIAL_REFRESH_SKEW_SECONDS=60
OPENSOCKET_PROTOCOL_VALIDATION_MODE=strict
OPENSOCKET_MAX_INBOUND_PAYLOAD_BYTES=1048576
OPENSOCKET_MAX_OUTBOUND_PAYLOAD_BYTES=1048576
OPENSOCKET_MAX_TASK_PAYLOAD_BYTES=524288
# Production always requires WSS; the local exception below is ignored in production.
OPENSOCKET_ALLOW_INSECURE_LOCAL_WS=true
OPENSOCKET_INSECURE_WS_ALLOWED_HOSTS=localhost,127.0.0.1,::1,host.docker.internal
OPENSOCKET_TENANT_ISOLATION_MODE=optional
OPENSOCKET_HEARTBEAT_INTERVAL_MS=15000
OPENSOCKET_HEARTBEAT_SAFETY_FACTOR=0.8
OPENSOCKET_HEARTBEAT_MIN_INTERVAL_MS=1000
OPENSOCKET_HEARTBEAT_MAX_INTERVAL_MS=60000
OPENSOCKET_HEARTBEAT_ACK_MODE=auto
OPENSOCKET_HEARTBEAT_ACK_TIMEOUT_MS=30000
OPENSOCKET_HEARTBEAT_MISSED_ACK_THRESHOLD=2
OPENSOCKET_SOCKET_CONNECT_TIMEOUT_MS=10000
OPENSOCKET_REGISTRATION_TIMEOUT_MS=10000
OPENSOCKET_RECONNECT_INITIAL_DELAY_MS=1000
OPENSOCKET_RECONNECT_MAX_DELAY_MS=30000
OPENSOCKET_RECONNECT_MULTIPLIER=2
OPENSOCKET_RECONNECT_FAST_ATTEMPTS=10
OPENSOCKET_RECONNECT_STEADY_DELAY_MS=60000
OPENSOCKET_RECONNECT_JITTER_RATIO=0.2
OPENSOCKET_TASK_TIMEOUT_MS=120000
OPENSOCKET_TASK_ACK_MODE=auto
OPENSOCKET_TASK_RESULT_ACK_TIMEOUT_MS=15000
OPENSOCKET_TASK_OUTBOX_RETRY_INTERVAL_MS=5000
OPENSOCKET_TASK_BUSY_RETRY_AFTER_MS=5000
OPENSOCKET_TASK_LEASE_RENEW_INTERVAL_MS=10000
OPENSOCKET_TASK_STATE_DIRECTORY=.opensocket-state
OPENSOCKET_TASK_RECONCILIATION_ENABLED=true
OPENSOCKET_LOG_LEVEL=debug
OPENSOCKET_AUTO_START=false
OPENSOCKET_STRICT_CONFIG=false
OPENSOCKET_EXECUTOR_MODE=openclaw-runtime
OPENSOCKET_OPENCLAW_RUNTIME_AGENT_ID=main
OPENSOCKET_OPENCLAW_MEMORY_SCOPE=assignment
OPENSOCKET_OPENCLAW_SESSION_PREFIX=opensocket
OPENSOCKET_OPENCLAW_PROGRESS_EVENTS_ENABLED=true
OPENSOCKET_OPENCLAW_STRUCTURED_OUTPUT_MODE=required
OPENSOCKET_OPENCLAW_RUNTIME_CLEANUP_MCP=true
OPENSOCKET_PROMPT_SECURITY_MODE=strict
OPENSOCKET_MAX_PROMPT_CHARACTERS=131072
OPENSOCKET_RAW_RESULT_MODE=redacted
OPENSOCKET_RAW_RESULT_INLINE_MAX_BYTES=16384
OPENSOCKET_ARTIFACT_DIRECTORY=.opensocket-artifacts
OPENSOCKET_ARTIFACT_MAX_BYTES=5242880
# M6 metrics, tracing, health and runtime observability
OPENSOCKET_OBSERVABILITY_ENABLED=true
OPENSOCKET_OBSERVABILITY_DIRECTORY=.opensocket-observability
OPENSOCKET_OBSERVABILITY_FLUSH_INTERVAL_MS=15000
OPENSOCKET_METRICS_ENABLED=true
OPENSOCKET_TRACING_ENABLED=true
OPENSOCKET_TRACE_SAMPLE_RATE=1
OPENSOCKET_TRACE_BUFFER_SIZE=200
OPENSOCKET_OBSERVABILITY_OUTBOX_WARNING_THRESHOLD=10
OPENSOCKET_OBSERVABILITY_OUTBOX_CRITICAL_THRESHOLD=100
OPENSOCKET_OBSERVABILITY_CREDENTIAL_EXPIRY_WARNING_SECONDS=300
# M7 capability-aware dispatcher and cluster routing
OPENSOCKET_SUPPORTED_TASK_TYPES=ISSUE_ANALYSIS,GENERIC_ANALYSIS
OPENSOCKET_SUPPORTED_ISSUE_PROVIDERS=JIRA,REDMINE,GITLAB
OPENSOCKET_MAX_CONCURRENT_TASKS=1
OPENSOCKET_TOOL_POLICIES=READ_ONLY,PROPOSE_ONLY
OPENSOCKET_CLUSTER_ROUTING_MODE=optional
OPENSOCKET_CLUSTER_REDIRECT_ALLOWED=true
OPENSOCKET_CLUSTER_REDIRECT_MAX_HOPS=5
OPENSOCKET_CLUSTER_OWNERSHIP_LEASE_SAFETY_FACTOR=0.8

