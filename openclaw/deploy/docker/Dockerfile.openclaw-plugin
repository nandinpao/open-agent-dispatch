# Build from the repository root after `npm run release:artifacts`:
# docker build -f deploy/docker/Dockerfile.openclaw-plugin \
#   --build-arg OPENCLAW_BASE_IMAGE=<approved-openclaw-image> \
#   -t <enterprise-openclaw-image-with-opensocket> .
ARG OPENCLAW_BASE_IMAGE
FROM ${OPENCLAW_BASE_IMAGE}

COPY release-artifacts/*.tgz /tmp/openclaw-plugin-opensocket.tgz
RUN openclaw plugins install /tmp/openclaw-plugin-opensocket.tgz \
    && rm -f /tmp/openclaw-plugin-opensocket.tgz
