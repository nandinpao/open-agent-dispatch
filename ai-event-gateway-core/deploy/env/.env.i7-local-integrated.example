# I7 local integrated profile
CORE_IMAGE=ai-event-gateway-core:local
NETTY_IMAGE=ai-event-gateway-netty:local
POSTGRES_IMAGE=postgres:18-alpine
REDIS_IMAGE=redis:8-alpine

CLUSTER_INTERNAL_TOKEN=local-i7-cluster-token-change-me
AGENT_ONBOARDING_TOKEN=local-agent-onboarding-token-change-me

CORE_INTERNAL_SECURITY_ENABLED=true
CORE_GATEWAY_INTERNAL_TOKEN=${CLUSTER_INTERNAL_TOKEN}
CORE_OPERATOR_INTERNAL_TOKEN=${CLUSTER_INTERNAL_TOKEN}
CORE_ACTUATOR_INTERNAL_TOKEN=${CLUSTER_INTERNAL_TOKEN}
CORE_INTERNAL_PROTECT_API_MUTATIONS=false
CORE_INTERNAL_PERMIT_ACTUATOR_HEALTH_INFO=true

GATEWAY_CORE_DIRECTORY_SYNC_ENABLED=true
GATEWAY_CORE_TASK_CALLBACK_RELAY_ENABLED=true
GATEWAY_CORE_TASK_CALLBACK_RELAY_REQUIRE_DISPATCH_CONTEXT=true
GATEWAY_CORE_OUTBOUND_ENABLED=true
GATEWAY_CORE_OUTBOUND_WORKER_THREADS=4
GATEWAY_CORE_OUTBOUND_QUEUE_CAPACITY=10000

DISPATCH_DEFAULT_GATEWAY_BASE_URL=http://netty:18081
DISPATCH_GATEWAY_DISPATCH_PATH=/internal/delivery/agents/{agentId}/commands
DISPATCH_INTERNAL_TOKEN_HEADER=X-Cluster-Token
