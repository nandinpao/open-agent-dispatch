# Host-local Core runtime against external/local services.
# Use this when running mvn spring-boot:run from the host instead of docker compose.

SPRING_PROFILES_ACTIVE=local

PG_SINGLE_URL=jdbc:postgresql://127.0.0.1:5432/aeg_core
PG_SINGLE_USERNAME=admin
PG_SINGLE_PASSWORD=123456

REDIS_ENABLED=true
REDIS_MODE=single
REDIS_DATABASE=0
REDIS_PASSWORD=123456
REDIS_TIMEOUT=30000
REDIS_SINGLE_ADDRESS=127.0.0.1:6379
REDIS_POOL_MAX_IDLE=16
REDIS_POOL_MIN_IDLE=8
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_WAIT=3000
REDIS_POOL_CONN_TIMEOUT=3000
REDIS_POOL_SO_TIMEOUT=3000
REDIS_POOL_SIZE=10
REDIS_CLUSTER_SCAN_INTERVAL=1000
REDIS_CLUSTER_NODE_0=127.0.0.1:7001
REDIS_CLUSTER_NODE_1=127.0.0.1:7002
REDIS_CLUSTER_NODE_2=127.0.0.1:7003
REDIS_CLUSTER_NODE_3=127.0.0.1:7004
REDIS_CLUSTER_NODE_4=127.0.0.1:7005
REDIS_CLUSTER_NODE_5=127.0.0.1:7006
REDIS_CLUSTER_READ_MODE=SLAVE
REDIS_CLUSTER_RETRY_ATTEMPTS=3
REDIS_CLUSTER_FAILED_ATTEMPTS=3
REDIS_CLUSTER_SLAVE_CONNECTION_POOL_SIZE=64
REDIS_CLUSTER_MASTER_CONNECTION_POOL_SIZE=64
REDIS_CLUSTER_RETRY_INTERVAL=1500

# Flyway owns schema lifecycle for existing PostgreSQL server.
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_VALIDATE_ON_MIGRATE=true
FLYWAY_OUT_OF_ORDER=false
FLYWAY_PRESTART_ENABLED=true

# PostgreSQL client for schema verification.
# psql is NOT required on the host. Use one of:
#   POSTGRES_CLIENT_MODE=docker-exec with POSTGRES_CONTAINER_NAME=<your-postgres-container>
#   POSTGRES_CLIENT_MODE=docker-run  with POSTGRES_CLIENT_IMAGE=postgres:18-alpine
# auto = host psql if available, otherwise docker-exec if POSTGRES_CONTAINER_NAME exists, otherwise docker-run.
POSTGRES_CLIENT_MODE=auto
POSTGRES_CONTAINER_NAME=
POSTGRES_CLIENT_IMAGE=postgres:18-alpine
POSTGRES_DOCKER_CLIENT_HOST=host.docker.internal
POSTGRES_CLIENT_DOCKER_NETWORK=
