# I7.10.2 Lombok adoption baseline.
# Lombok is allowed for PO/DTO boilerplate reduction, but domain and security code must remain explicit.
config.stopBubbling = true

lombok.addLombokGeneratedAnnotation = true
lombok.anyConstructor.addConstructorProperties = true

# Avoid blanket Lombok shortcuts in production domain code.
lombok.data.flagUsage = warning
lombok.value.flagUsage = warning
lombok.var.flagUsage = error
lombok.val.flagUsage = warning

# Prevent accidental logging based on all fields. Lombok has no global
# equals/hashCode onlyExplicitlyIncluded config key, so flag direct usage
# and require explicit review when EqualsAndHashCode is introduced.
lombok.toString.onlyExplicitlyIncluded = true
lombok.equalsAndHashCode.flagUsage = warning

lombok.nonNull.exceptionType = IllegalArgumentException
