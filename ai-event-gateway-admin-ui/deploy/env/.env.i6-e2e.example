# I6 Core + Netty + Mock Agent E2E example
# Copy to .env.i6-e2e and replace secrets before sharing outside local machines.

COMPOSE_PROJECT_NAME=opensocket-i6-e2e
TZ=Asia/Taipei

# Service ports exposed to host
CORE_PORT=18080
NETTY_ADMIN_PORT=18081
NETTY_TCP_PORT=19090
NETTY_WS_PORT=19091

# Images. Build these from each project first, or override with CI image names.
CORE_IMAGE=ai-event-gateway-core:local
NETTY_IMAGE=ai-event-gateway-netty:local

# Shared internal token for local E2E only.
CLUSTER_INTERNAL_TOKEN=local-i6-internal-token-change-me

# Core runtime. I6 uses database-backed stores so state can be verified after callbacks.
SPRING_PROFILES_ACTIVE=local
CORE_INTERNAL_SECURITY_ENABLED=true
CORE_INTERNAL_PROTECT_API_MUTATIONS=false
CORE_INTERNAL_PERMIT_ACTUATOR_HEALTH_INFO=true
CORE_GATEWAY_INTERNAL_TOKEN=local-i6-internal-token-change-me
CORE_OPERATOR_INTERNAL_TOKEN=local-i6-internal-token-change-me
CORE_ACTUATOR_INTERNAL_TOKEN=local-i6-internal-token-change-me
DATABASE_PLATFORM_REQUIRE_DATASOURCE=true
DATABASE_PLATFORM_REQUIRE_FLYWAY=true
INCIDENT_STORE=MYBATIS
INCIDENT_SUMMARY_STORE=MYBATIS
EVENT_DECISION_STORE=MYBATIS
TASK_STORE=MYBATIS
TASK_CALLBACK_STORE=MYBATIS
DISPATCH_REQUEST_STORE=MYBATIS
AGENT_DIRECTORY_STORE=MYBATIS
CORE_TASK_CREATION_ENABLED=true
CORE_TASK_MIN_OCCURRENCES=1
CORE_IMMEDIATE_TASK_SEVERITIES=CRITICAL,HIGH
CORE_DEFAULT_ROUTING_POLICY=LOCAL_FIRST
CORE_DEFAULT_TASK_CAPABILITIES=incident-analysis
DISPATCH_REQUEST_CREATION_ENABLED=true
DISPATCH_REVIEW_MODE=AUTO_APPROVE
DISPATCH_CLIENT_ENABLED=true
DISPATCH_CLIENT_AUTO_EXECUTE_APPROVED=true
DISPATCH_EXECUTION_POLICY=AUTO_AFTER_ASSIGNMENT
DISPATCH_DEFAULT_GATEWAY_BASE_URL=http://netty:18080
DISPATCH_INTERNAL_TOKEN=local-i6-internal-token-change-me

# Netty runtime.
GATEWAY_NODE_ID=gateway-node-001
GATEWAY_SITE_ID=LOCAL
GATEWAY_REGION=local
GATEWAY_ZONE=local-zone-a
GATEWAY_CORE_OUTBOUND_ENABLED=true
GATEWAY_CORE_OUTBOUND_WORKER_THREADS=2
GATEWAY_CORE_OUTBOUND_QUEUE_CAPACITY=1000
GATEWAY_CORE_DIRECTORY_SYNC_ENABLED=true
GATEWAY_CORE_DIRECTORY_SYNC_BASE_URL=http://core:18080
GATEWAY_CORE_DIRECTORY_SYNC_AUTH_TOKEN=local-i6-internal-token-change-me
GATEWAY_CORE_DIRECTORY_SYNC_GATEWAY_HEARTBEAT_INTERVAL_MS=5000
GATEWAY_CORE_DIRECTORY_SYNC_SNAPSHOT_INTERVAL_MS=10000
GATEWAY_CORE_TASK_CALLBACK_RELAY_ENABLED=true
GATEWAY_CORE_TASK_CALLBACK_RELAY_BASE_URL=http://core:18080
GATEWAY_CORE_TASK_CALLBACK_RELAY_AUTH_TOKEN=local-i6-internal-token-change-me
GATEWAY_CORE_TASK_CALLBACK_RELAY_REQUIRE_DISPATCH_CONTEXT=true
GATEWAY_CORE_FORWARD_ENABLED=false
AGENT_AUTH_ENABLED=false
ADMIN_AUTH_ENABLED=false

# E2E runner / mock agent.
I6_CORE_BASE_URL=http://127.0.0.1:18080
I6_NETTY_ADMIN_BASE_URL=http://127.0.0.1:18081
I6_GATEWAY_TCP_HOST=127.0.0.1
I6_GATEWAY_TCP_PORT=19090
I6_GATEWAY_NODE_ID=gateway-node-001
I6_AGENT_ID=agent-i6-001
I6_AGENT_CAPABILITIES=incident-analysis
I6_WAIT_TIMEOUT_SECONDS=120
