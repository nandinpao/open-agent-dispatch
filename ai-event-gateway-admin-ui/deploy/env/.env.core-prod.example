# ai-event-gateway-core prod profile
# ----------------------------------
# Purpose: production baseline.
# External dependencies: PostgreSQL + Redis + ai-event-gateway-netty + external adapter workers.
# Replace every <...> value before use. Do not commit the real prod file.
# Database and Redis settings intentionally use SharedUtility keys: pg.single and redis.*.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=18080

# Database platform strict startup validation
DATABASE_PLATFORM_ENABLED=true
DATABASE_PLATFORM_HEALTH_ENABLED=true
DATABASE_PLATFORM_VALIDATE_ON_STARTUP=true

# SharedUtility database toggle
PG_ENABLED=true
PG_MYBATIS_ENABLED=true
PG_MYBATIS_STATEMENT_TIMEOUT=10

# SharedUtility pg.single
PG_SINGLE_NAME=single
PG_SINGLE_URL=jdbc:postgresql://<db-host>:5432/aeg_core
PG_SINGLE_USERNAME=<db-user>
PG_SINGLE_PASSWORD=<db-password>
PG_SINGLE_IS_DEFAULT=true
PG_SINGLE_DRIVER_CLASS_NAME=org.postgresql.Driver
PG_SINGLE_HIKARI_MINIMUM_IDLE=5
PG_SINGLE_HIKARI_MAXIMUM_POOL_SIZE=30
PG_SINGLE_HIKARI_CONNECTION_TIMEOUT=30000
PG_SINGLE_HIKARI_IDLE_TIMEOUT=30000
PG_SINGLE_HIKARI_MAX_LIFETIME=1800000
PG_SINGLE_HIKARI_POOL_NAME=AegCoreSinglePool

# Flyway uses the SharedUtility pg.single DataSource in dev/prod.
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# SharedUtility redisson-client settings.
# For single mode, set REDIS_SINGLE_ADDRESS=<redis-host>:6379.
# For cluster mode, set REDIS_MODE=cluster and fill REDIS_CLUSTER_NODE_0..N.
REDIS_ENABLED=true
REDIS_MODE=single
REDIS_DATABASE=0
REDIS_PASSWORD=<redis-password>
REDIS_TIMEOUT=30000
REDIS_SINGLE_ADDRESS=<redis-host>:6379
REDIS_POOL_MAX_IDLE=16
REDIS_POOL_MIN_IDLE=8
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_WAIT=3000
REDIS_POOL_CONN_TIMEOUT=3000
REDIS_POOL_SO_TIMEOUT=3000
REDIS_POOL_SIZE=10
REDIS_CLUSTER_SCAN_INTERVAL=1000
REDIS_CLUSTER_NODE_0=
REDIS_CLUSTER_NODE_1=
REDIS_CLUSTER_NODE_2=
REDIS_CLUSTER_NODE_3=
REDIS_CLUSTER_NODE_4=
REDIS_CLUSTER_NODE_5=
REDIS_CLUSTER_READ_MODE=SLAVE
REDIS_CLUSTER_RETRY_ATTEMPTS=3
REDIS_CLUSTER_FAILED_ATTEMPTS=3
REDIS_CLUSTER_SLAVE_CONNECTION_POOL_SIZE=64
REDIS_CLUSTER_MASTER_CONNECTION_POOL_SIZE=64
REDIS_CLUSTER_RETRY_INTERVAL=1500
REDIS_STREAM_AUTOCLAIM_ENABLED=true
REDIS_STREAM_AUTOCLAIM_IDLE=60s
REDIS_STREAM_AUTOCLAIM_INTERVAL=5s
REDIS_STREAM_AUTOCLAIM_BATCH=100
REDIS_STREAM_AUTOCLAIM_MAX_ROUNDS=5

# Store mode. Dedup uses SharedUtility RedissonAccess, not Spring Data Redis.
EVENT_DECISION_STORE=MYBATIS
EVENT_DEDUP_STORE=REDISSON
EVENT_DEDUP_SNAPSHOT_STORE=MYBATIS
INCIDENT_STORE=MYBATIS
INCIDENT_SUMMARY_STORE=MYBATIS
TASK_STORE=MYBATIS
TASK_CALLBACK_STORE=MYBATIS
GATEWAY_NODE_STORE=MYBATIS
AGENT_DIRECTORY_STORE=MYBATIS
ASSIGNMENT_STORE=MYBATIS
ROUTING_DECISION_STORE=MYBATIS
DISPATCH_REQUEST_STORE=MYBATIS
ADAPTER_ACTION_STORE=MYBATIS
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS

# Production behavior
CORE_TASK_CREATION_ENABLED=true
CORE_DEFAULT_ROUTING_POLICY=LOCAL_FIRST
ROUTING_ASSIGNMENT_ENABLED=true
DISPATCH_REQUEST_CREATION_ENABLED=true
DISPATCH_REVIEW_MODE=AUTO_APPROVE
DISPATCH_CLIENT_ENABLED=true
DISPATCH_CLIENT_AUTO_EXECUTE_APPROVED=true
DISPATCH_EXECUTION_POLICY=AUTO_AFTER_ASSIGNMENT
DISPATCH_DEFAULT_GATEWAY_BASE_URL=http://<ai-event-gateway-netty-host>:18081
DISPATCH_INTERNAL_TOKEN=<change-me>
DISPATCH_GATEWAY_TPE_001_BASE_URL=http://<gateway-tpe-001>:18081
DISPATCH_GATEWAY_TYN_001_BASE_URL=http://<gateway-tyn-001>:18081
DISPATCH_GATEWAY_TNN_001_BASE_URL=http://<gateway-tnn-001>:18081

# Callback reliability must remain strict in production.
TASK_CALLBACK_REQUIRE_DISPATCH_TOKEN=true
TASK_CALLBACK_ALLOW_MISSING_DISPATCH_REQUEST_ID=false
TASK_CALLBACK_REQUIRE_ATTEMPT_NO=true
TASK_CALLBACK_ENFORCE_GATEWAY_AGENT_IDENTITY=true
DISPATCH_RECOVERY_TIMEOUT_ENABLED=true
DISPATCH_RECOVERY_RETRY_ENABLED=true

# Adapter action / executor behavior. Production expects external workers.
MCP_ACTION_ENABLED=false
ISSUE_ACTION_ENABLED=false
ADAPTER_EXECUTOR_MODE=external
ADAPTER_EXECUTOR_ENABLED=false
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=false

# I7.5 production mock executor purge: production must never return mock success.
ADAPTER_EXECUTOR_MOCK_ENABLED=false
ADAPTER_EXECUTOR_LEGACY_ISSUE_ENABLED=false
MCP_EXECUTOR_MOCK_COMPATIBLE=false
ISSUE_EXECUTOR_DEFAULT_VENDOR=
JIRA_EXECUTOR_MOCK_ENABLED=false
REDMINE_EXECUTOR_MOCK_ENABLED=false
GITLAB_EXECUTOR_MOCK_ENABLED=false
JIRA_EXECUTOR_NAME=jira-issue-executor
REDMINE_EXECUTOR_NAME=redmine-issue-executor
GITLAB_EXECUTOR_NAME=gitlab-issue-executor
ADAPTER_EXECUTOR_MOCK_ENABLED=false
MCP_EXECUTOR_ENDPOINT_URL=
MCP_EXECUTOR_BEARER_TOKEN=

# I5 production security baseline. Replace all values and keep role tokens distinct.
CORE_INTERNAL_SECURITY_ENABLED=true
CORE_GATEWAY_INTERNAL_TOKEN=<gateway-service-token>
CORE_ADAPTER_WORKER_INTERNAL_TOKEN=<adapter-worker-service-token>
CORE_OPERATOR_INTERNAL_TOKEN=<operator-service-token>
CORE_ACTUATOR_INTERNAL_TOKEN=<actuator-ops-token>
CORE_INTERNAL_PROTECT_API_MUTATIONS=true
CORE_INTERNAL_PERMIT_ACTUATOR_HEALTH_INFO=false
CORE_INTERNAL_SECURITY_AUDIT_LOG_ENABLED=true
CORE_INTERNAL_ALLOW_LEGACY_TOKEN_HEADER=false
MANAGEMENT_HEALTH_SHOW_DETAILS=never
MANAGEMENT_INFO_ENV_ENABLED=false

# Issue Tracking / Redmine executor settings
ISSUE_ACTION_ENABLED=false
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=false
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=false
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=false
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS
ISSUE_EXECUTOR_DEFAULT_VENDOR=REDMINE
REDMINE_EXECUTOR_ENABLED=false
REDMINE_EXECUTOR_BASE_URL=REPLACE_WITH_REDMINE_BASE_URL
REDMINE_EXECUTOR_API_KEY=REPLACE_WITH_REDMINE_API_KEY
REDMINE_EXECUTOR_PROJECT_ID=REPLACE_WITH_REDMINE_PROJECT_IDENTIFIER_OR_ID
REDMINE_EXECUTOR_TRACKER_ID=1
REDMINE_EXECUTOR_ISSUE_URL_TEMPLATE=REPLACE_WITH_REDMINE_ISSUE_URL_TEMPLATE
