# ai-event-gateway-core local profile
# -----------------------------------
# Purpose: local Docker / local developer integration.
# External dependencies: PostgreSQL + Redis, provided by docker-compose.core-local.yml by default.
# Database and Redis settings intentionally use SharedUtility keys: pg.single and redis.*.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=18080

# SharedUtility database toggle
PG_ENABLED=true
PG_MYBATIS_ENABLED=true
PG_MYBATIS_STATEMENT_TIMEOUT=10

# SharedUtility pg.single
# In Docker compose, use service name postgres. For IDE run outside Docker, change host to 127.0.0.1.
PG_SINGLE_NAME=single
PG_SINGLE_URL=jdbc:postgresql://host.docker.internal:5432/aeg_core
PG_SINGLE_USERNAME=admin
PG_SINGLE_PASSWORD=123456
PG_SINGLE_IS_DEFAULT=true
PG_SINGLE_DRIVER_CLASS_NAME=org.postgresql.Driver
PG_SINGLE_HIKARI_MINIMUM_IDLE=2
PG_SINGLE_HIKARI_MAXIMUM_POOL_SIZE=10
PG_SINGLE_HIKARI_CONNECTION_TIMEOUT=30000
PG_SINGLE_HIKARI_IDLE_TIMEOUT=30000
PG_SINGLE_HIKARI_MAX_LIFETIME=1800000
PG_SINGLE_HIKARI_POOL_NAME=AegCoreLocalSinglePool

# Flyway uses the SharedUtility pg.single DataSource in local/dev/prod.
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# SharedUtility redisson-client settings
REDIS_ENABLED=true
REDIS_MODE=single
REDIS_DATABASE=0
REDIS_PASSWORD=123456
REDIS_TIMEOUT=30000
REDIS_SINGLE_ADDRESS=baofire.com:6379
REDIS_POOL_MAX_IDLE=16
REDIS_POOL_MIN_IDLE=8
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_WAIT=3000
REDIS_POOL_CONN_TIMEOUT=3000
REDIS_POOL_SO_TIMEOUT=3000
REDIS_POOL_SIZE=10
REDIS_CLUSTER_SCAN_INTERVAL=1000
REDIS_CLUSTER_NODE_0=baofire.com:7001
REDIS_CLUSTER_NODE_1=baofire.com:7002
REDIS_CLUSTER_NODE_2=baofire.com:7003
REDIS_CLUSTER_NODE_3=baofire.com:7004
REDIS_CLUSTER_NODE_4=baofire.com:7005
REDIS_CLUSTER_NODE_5=baofire.com:7006
REDIS_CLUSTER_READ_MODE=SLAVE
REDIS_CLUSTER_RETRY_ATTEMPTS=3
REDIS_CLUSTER_FAILED_ATTEMPTS=3
REDIS_CLUSTER_SLAVE_CONNECTION_POOL_SIZE=64
REDIS_CLUSTER_MASTER_CONNECTION_POOL_SIZE=64
REDIS_CLUSTER_RETRY_INTERVAL=1500
REDIS_STREAM_AUTOCLAIM_ENABLED=true
REDIS_STREAM_AUTOCLAIM_IDLE=60s
REDIS_STREAM_AUTOCLAIM_INTERVAL=5s
REDIS_STREAM_AUTOCLAIM_BATCH=100
REDIS_STREAM_AUTOCLAIM_MAX_ROUNDS=5

# Store mode. Local intentionally matches dev: SharedUtility MyBatis where implemented, PostgreSQL fallback elsewhere.
# Dedup uses SharedUtility RedissonAccess, not Spring Data Redis.
EVENT_DECISION_STORE=MYBATIS
EVENT_DEDUP_STORE=REDISSON
EVENT_DEDUP_SNAPSHOT_STORE=MYBATIS
INCIDENT_STORE=MYBATIS
INCIDENT_SUMMARY_STORE=MYBATIS
TASK_STORE=MYBATIS
TASK_CALLBACK_STORE=MYBATIS
GATEWAY_NODE_STORE=MYBATIS
AGENT_DIRECTORY_STORE=MYBATIS
ASSIGNMENT_STORE=MYBATIS
ROUTING_DECISION_STORE=MYBATIS
DISPATCH_REQUEST_STORE=MYBATIS
ADAPTER_ACTION_STORE=MYBATIS
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS

# Decision / routing / dispatch behavior
CORE_TASK_CREATION_ENABLED=true
CORE_DEFAULT_ROUTING_POLICY=LOCAL_FIRST
ROUTING_ASSIGNMENT_ENABLED=true
DISPATCH_REQUEST_CREATION_ENABLED=true
DISPATCH_REVIEW_MODE=AUTO_APPROVE
DISPATCH_CLIENT_ENABLED=true
DISPATCH_CLIENT_AUTO_EXECUTE_APPROVED=true
DISPATCH_EXECUTION_POLICY=AUTO_AFTER_ASSIGNMENT
DISPATCH_DEFAULT_GATEWAY_BASE_URL=http://host.docker.internal:18081
DISPATCH_INTERNAL_TOKEN=local-internal-token-change-me
DISPATCH_GATEWAY_TPE_001_BASE_URL=http://host.docker.internal:18081
DISPATCH_GATEWAY_TYN_001_BASE_URL=http://host.docker.internal:18082
DISPATCH_GATEWAY_TNN_001_BASE_URL=http://host.docker.internal:18083

# Local now matches dev callback strictness.
TASK_CALLBACK_REQUIRE_DISPATCH_TOKEN=true
TASK_CALLBACK_ALLOW_MISSING_DISPATCH_REQUEST_ID=false
TASK_CALLBACK_REQUIRE_ATTEMPT_NO=true
TASK_CALLBACK_ENFORCE_GATEWAY_AGENT_IDENTITY=true
DISPATCH_RECOVERY_TIMEOUT_ENABLED=true
DISPATCH_RECOVERY_RETRY_ENABLED=true

# Adapter action / executor behavior
MCP_ACTION_ENABLED=false
ISSUE_ACTION_ENABLED=false
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=true
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=false
ADAPTER_EXECUTOR_MOCK_ENABLED=true
MCP_EXECUTOR_ENDPOINT_URL=
MCP_EXECUTOR_BEARER_TOKEN=

# I5 local integrated security. Enable when testing Netty/Core service tokens.
CORE_INTERNAL_SECURITY_ENABLED=false
CORE_GATEWAY_INTERNAL_TOKEN=local-internal-token-change-me
CORE_ADAPTER_WORKER_INTERNAL_TOKEN=local-adapter-worker-token-change-me
CORE_OPERATOR_INTERNAL_TOKEN=local-operator-token-change-me
CORE_RECOVERY_OPERATOR_INTERNAL_TOKEN=local-recovery-operator-token-change-me
CORE_RECOVERY_ADMIN_INTERNAL_TOKEN=local-recovery-admin-token-change-me
CORE_ACTUATOR_INTERNAL_TOKEN=local-actuator-token-change-me
CORE_INTERNAL_PROTECT_API_MUTATIONS=false
CORE_RECOVERY_GOVERNANCE_REQUIRE_REASON=true
CORE_RECOVERY_GOVERNANCE_REQUIRE_CONFIRMATION=true
CORE_RECOVERY_GOVERNANCE_MIN_REASON_LENGTH=12

# Issue Tracking / Redmine executor settings
ISSUE_ACTION_ENABLED=true
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=true
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=true
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=true
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS
ISSUE_EXECUTOR_DEFAULT_VENDOR=REDMINE
REDMINE_EXECUTOR_ENABLED=true
REDMINE_EXECUTOR_BASE_URL=http://baofire.com:8700
REDMINE_EXECUTOR_API_KEY=REPLACE_WITH_REDMINE_API_KEY
REDMINE_EXECUTOR_PROJECT_ID=REPLACE_WITH_REDMINE_PROJECT_IDENTIFIER_OR_ID
REDMINE_EXECUTOR_TRACKER_ID=1
REDMINE_EXECUTOR_ISSUE_URL_TEMPLATE=http://baofire.com:8700/issues/%s
