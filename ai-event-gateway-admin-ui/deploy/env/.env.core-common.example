# ai-event-gateway-core common environment template
# ------------------------------------------------
# This file contains non-secret, cross-environment defaults.
# Docker compose loads this file first, then loads one of:
#   - .env.core-local.example
#   - .env.core-dev.example
#   - .env.core-prod.example
#
# For real deployment, copy the relevant files and remove the .example suffix.

# Server / actuator
SERVER_PORT=18080
MANAGEMENT_ENDPOINTS=health,info,metrics,prometheus


# P25.2 P0 database platform bootstrap
DATABASE_PLATFORM_ENABLED=true
DATABASE_PLATFORM_HEALTH_ENABLED=true
DATABASE_PLATFORM_VALIDATE_ON_STARTUP=false
DATABASE_PLATFORM_REQUIRE_DATASOURCE=true
DATABASE_PLATFORM_REQUIRE_SQL_SESSION_FACTORY=true
DATABASE_PLATFORM_REQUIRE_FLYWAY=true
DATABASE_PLATFORM_VALIDATION_TIMEOUT=2s

# Decision window / task threshold defaults
CORE_DEDUP_WINDOW=5m
CORE_DEDUP_TTL=2h
CORE_INCIDENT_TTL=12h
CORE_TASK_ESCALATION_ENABLED=true
CORE_TASK_MIN_OCCURRENCES=30
CORE_IMMEDIATE_TASK_SEVERITIES=CRITICAL
CORE_DEFAULT_TASK_CAPABILITIES=incident-analysis

# Phase 2 fingerprint policy defaults
CORE_FINGERPRINT_ENABLED=true
CORE_FINGERPRINT_POLICY_VERSION=v2
CORE_FINGERPRINT_MASKING_ENABLED=true

# Incident summary
INCIDENT_SUMMARY_WINDOW=5m

# Routing / directory maintenance
ROUTING_MINIMUM_SCORE=50
ROUTING_MAX_CANDIDATES=20
ROUTING_UPDATE_TASK_STATUS_ON_ASSIGNMENT=true
GATEWAY_NODE_LEASE_REAPER_DELAY=10000
AGENT_DIRECTORY_LEASE_REAPER_DELAY=10000

# Dispatch defaults
DISPATCH_SOURCE_NODE_ID=ai-event-gateway-core
DISPATCH_WORKER_ID=core-dispatch
DISPATCH_CLAIM_LEASE=30s
DISPATCH_GATEWAY_DISPATCH_PATH=/internal/gateway/tasks/dispatch
DISPATCH_REQUIRE_ASSIGNABLE_AGENT=true
DISPATCH_RETRY_ENABLED=true
DISPATCH_RETRY_MAX_ATTEMPTS=3
DISPATCH_RETRY_INITIAL_BACKOFF=30s
DISPATCH_RETRY_MAX_BACKOFF=5m
DISPATCH_CLIENT_AUTO_EXECUTE_INTERVAL_MS=5000
DISPATCH_CLIENT_CONNECT_TIMEOUT=3s
DISPATCH_CLIENT_REQUEST_TIMEOUT=10s
DISPATCH_CLIENT_MAX_BATCH_SIZE=100
DISPATCH_INTERNAL_TOKEN_HEADER=X-Internal-Token

# Callback reliability defaults. Local may relax these in .env.core-local.example.
TASK_CALLBACK_IDEMPOTENCY_ENABLED=true
TASK_CALLBACK_ENFORCE_STATE_TRANSITION=true
TASK_CALLBACK_REJECT_OLD_ATTEMPT_CALLBACKS=true
TASK_CALLBACK_ALLOW_TERMINAL_CALLBACK_OVERRIDE=false
TASK_CALLBACK_MAX_RECENT=1000
DISPATCH_RECOVERY_SCAN_INTERVAL_MS=30000
DISPATCH_RECOVERY_DISPATCH_TIMEOUT=10m
DISPATCH_RECOVERY_AUTO_FAIL_TIMED_OUT=true
DISPATCH_RECOVERY_MAX_ATTEMPTS=3
DISPATCH_RECOVERY_INITIAL_BACKOFF=30s
DISPATCH_RECOVERY_MAX_BACKOFF=5m
DISPATCH_RECOVERY_MAX_BATCH_SIZE=100

# Adapter action defaults
ADAPTER_ACTION_CREATE_SUPPRESSED_RECORDS=true
MCP_ACTION_RUN_ON_COMPLETED_TASK=true
MCP_ACTION_RUN_ON_FAILED_TASK=false
MCP_ACTION_ONE_PER_TASK=true
MCP_ADAPTER_NAME=mcp-default
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=false
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ISSUE_ACTION_ONE_CREATE_PER_INCIDENT=true
ISSUE_ACTION_ONE_UPDATE_PER_TASK=true
ISSUE_ADAPTER_NAME=issue-default

# Adapter executor defaults
ADAPTER_EXECUTOR_AUTO_EXECUTE_INTERVAL=10s
ADAPTER_EXECUTOR_AUTO_EXECUTE_INTERVAL_MS=10000
ADAPTER_EXECUTOR_BATCH_SIZE=50
ADAPTER_EXECUTOR_MAX_ATTEMPTS=3
ADAPTER_EXECUTOR_INITIAL_BACKOFF=30s
ADAPTER_EXECUTOR_MAX_BACKOFF=10m
ADAPTER_EXECUTOR_EXECUTION_TIMEOUT=30s
ADAPTER_EXECUTOR_MARK_UNAVAILABLE_WHEN_NO_EXECUTOR=true
ADAPTER_EXECUTOR_CIRCUIT_BREAKER_ENABLED=true
ADAPTER_EXECUTOR_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
ADAPTER_EXECUTOR_CIRCUIT_BREAKER_OPEN_DURATION=1m
ADAPTER_EXECUTOR_MOCK_ENABLED=false
ADAPTER_EXECUTOR_MCP_NAME=mcp-http-executor
ADAPTER_EXECUTOR_ISSUE_NAME=issue-tracking-executor-router
ADAPTER_EXECUTOR_LEGACY_ISSUE_ENABLED=false

# HTTP MCP executor defaults
MCP_EXECUTOR_HTTP_ENABLED=false
MCP_EXECUTOR_NAME=mcp-http-executor
MCP_EXECUTOR_TIMEOUT=30s
MCP_EXECUTOR_MOCK_COMPATIBLE=false

# Issue executor defaults
ISSUE_EXECUTOR_DEFAULT_VENDOR=
JIRA_EXECUTOR_MOCK_ENABLED=false
REDMINE_EXECUTOR_MOCK_ENABLED=false
GITLAB_EXECUTOR_MOCK_ENABLED=false
JIRA_EXECUTOR_NAME=jira-issue-executor
REDMINE_EXECUTOR_NAME=redmine-issue-executor
GITLAB_EXECUTOR_NAME=gitlab-issue-executor

# Audit defaults
ADAPTER_EXECUTOR_AUDIT_PAYLOAD_SNAPSHOT_ENABLED=true


# Phase 3 incident / task lifecycle
INCIDENT_LIFECYCLE_AUTO_RESOLVE_ENABLED=true
INCIDENT_LIFECYCLE_SCAN_INTERVAL_MS=60000
INCIDENT_LIFECYCLE_INACTIVE_THRESHOLD=12h
INCIDENT_LIFECYCLE_MAX_BATCH_SIZE=100
INCIDENT_LIFECYCLE_REOPEN_POLICY=REOPEN_RECENT
INCIDENT_LIFECYCLE_REOPEN_WINDOW=24h
TASK_LIFECYCLE_TIMEOUT_ENABLED=true
TASK_LIFECYCLE_AUTO_REASSIGN_ENABLED=true
TASK_LIFECYCLE_SCAN_INTERVAL_MS=30000
TASK_LIFECYCLE_CREATED_TIMEOUT=10m
TASK_LIFECYCLE_ASSIGNED_TIMEOUT=10m
TASK_LIFECYCLE_DISPATCHED_TIMEOUT=10m
TASK_LIFECYCLE_RUNNING_TIMEOUT=30m
TASK_LIFECYCLE_MAX_REASSIGNMENTS=2
TASK_LIFECYCLE_MAX_BATCH_SIZE=100

# Phase 4 adapter external worker reliability
ADAPTER_WORKER_RETRY_ENABLED=true
ADAPTER_WORKER_MAX_ATTEMPTS=3
ADAPTER_WORKER_INITIAL_BACKOFF=30s
ADAPTER_WORKER_MAX_BACKOFF=10m
ADAPTER_WORKER_EXPIRED_LEASE_SCAN_BATCH_SIZE=100
ADAPTER_WORKER_EXPIRED_LEASE_SCAN_INTERVAL_MS=30000

# Phase 5 observability / operations
CORE_OBSERVABILITY_ENABLED=true
CORE_OBSERVABILITY_BUSINESS_METRICS_ENABLED=true
CORE_OBSERVABILITY_REPOSITORY_SUMMARY_ENABLED=true
CORE_OBSERVABILITY_HEALTH_INDICATOR_ENABLED=true
CORE_OBSERVABILITY_INCLUDE_TENANT_TAG=false
CORE_OBSERVABILITY_INCLUDE_SITE_TAG=true
CORE_OBSERVABILITY_SUMMARY_SAMPLE_LIMIT=500
CORE_OBSERVABILITY_SLOW_INTAKE_THRESHOLD=3s
MANAGEMENT_HEALTH_SHOW_DETAILS=when_authorized

# M7 transactional outbox
CORE_OUTBOX_STORE=MYBATIS
CORE_OUTBOX_DISPATCHER_ENABLED=true
CORE_OUTBOX_WORKER_ID=core-outbox
CORE_OUTBOX_CLAIM_LEASE=30s
CORE_OUTBOX_SCAN_INTERVAL_MS=1000
CORE_OUTBOX_BATCH_SIZE=100
CORE_OUTBOX_MAX_ATTEMPTS=8
CORE_OUTBOX_INITIAL_BACKOFF=2s
CORE_OUTBOX_MAX_BACKOFF=5m

# M8 service extraction / integration event output
CORE_INTEGRATION_EVENTS_PROJECTION_ENABLED=false
CORE_INTEGRATION_EVENTS_DELIVERY_ENABLED=false
CORE_INTEGRATION_EVENTS_STORE=MYBATIS
CORE_INTEGRATION_EVENTS_SOURCE=ai-event-gateway-core
CORE_INTEGRATION_EVENTS_WORKER_ID=core-integration-events
CORE_INTEGRATION_EVENTS_SINK=NONE
CORE_INTEGRATION_EVENTS_ENDPOINT_URL=
CORE_INTEGRATION_EVENTS_TOKEN_HEADER=X-Internal-Token
CORE_INTEGRATION_EVENTS_TOKEN=
CORE_DEPLOYMENT_MODE=MODULAR_MONOLITH

# I5 Core internal API security baseline
# Local migration may keep this false. Dev/prod should enable it and set separate tokens per role.
CORE_INTERNAL_SECURITY_ENABLED=false
CORE_INTERNAL_TOKEN_HEADER=X-Cluster-Token
CORE_INTERNAL_LEGACY_TOKEN_HEADER=X-Internal-Token
CORE_INTERNAL_ALLOW_LEGACY_TOKEN_HEADER=true
CORE_INTERNAL_PROTECT_API_MUTATIONS=false
CORE_INTERNAL_PERMIT_ACTUATOR_HEALTH_INFO=true
CORE_INTERNAL_SECURITY_AUDIT_LOG_ENABLED=true
CORE_GATEWAY_INTERNAL_TOKEN=
CORE_ADAPTER_WORKER_INTERNAL_TOKEN=
CORE_OPERATOR_INTERNAL_TOKEN=
CORE_ACTUATOR_INTERNAL_TOKEN=
MANAGEMENT_INFO_ENV_ENABLED=false

# P1.8 Core-enforced Netty runtime disconnect after blocking governance transitions.
# This URL must be reachable from the Core process/container, not from the browser.
CORE_RUNTIME_DISCONNECT_ENABLED=true
CORE_RUNTIME_DISCONNECT_DEFAULT_GATEWAY_BASE_URL=http://localhost:18081
CORE_RUNTIME_DISCONNECT_GATEWAY_NODE_001_BASE_URL=http://localhost:18081
CORE_RUNTIME_DISCONNECT_GATEWAY_NODE_002_BASE_URL=http://localhost:18082
CORE_RUNTIME_DISCONNECT_GATEWAY_NODE_003_BASE_URL=http://localhost:18083
CORE_RUNTIME_DISCONNECT_TOKEN_HEADER=Authorization
CORE_RUNTIME_DISCONNECT_AUTHORIZATION_SCHEME=Bearer
CORE_RUNTIME_DISCONNECT_ADMIN_TOKEN=local-admin-api-token-change-me
CORE_RUNTIME_DISCONNECT_REQUEST_TIMEOUT=3s
# Production owner-node URLs should point to actual Netty Admin API service names, for example:
# CORE_RUNTIME_DISCONNECT_GATEWAY_NODE_001_BASE_URL=http://netty-node-001:18081
# CORE_RUNTIME_DISCONNECT_GATEWAY_NODE_002_BASE_URL=http://netty-node-002:18082

# Issue Tracking / Redmine executor settings
ISSUE_ACTION_ENABLED=true
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=true
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=true
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=true
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS
ISSUE_EXECUTOR_DEFAULT_VENDOR=REDMINE
REDMINE_EXECUTOR_ENABLED=true
REDMINE_EXECUTOR_BASE_URL=http://baofire.com:8700
REDMINE_EXECUTOR_API_KEY=REPLACE_WITH_REDMINE_API_KEY
REDMINE_EXECUTOR_PROJECT_ID=REPLACE_WITH_REDMINE_PROJECT_IDENTIFIER_OR_ID
REDMINE_EXECUTOR_TRACKER_ID=1
REDMINE_EXECUTOR_ISSUE_URL_TEMPLATE=http://baofire.com:8700/issues/%s
