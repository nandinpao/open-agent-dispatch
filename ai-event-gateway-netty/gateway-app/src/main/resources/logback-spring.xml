<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds">
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="ai-event-gateway-netty"/>
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>
    <property name="ROOT_LEVEL" value="${LOG_LEVEL_ROOT:-INFO}"/>
    <property name="GATEWAY_LEVEL" value="${LOG_LEVEL_GATEWAY:-INFO}"/>
    <property name="LOG_LEVEL_TRACING" value="${LOG_LEVEL_TRACING:-INFO}"/>
    <property name="LOG_MAX_FILE_SIZE" value="${LOG_MAX_FILE_SIZE:-50MB}"/>
    <property name="LOG_MAX_HISTORY" value="${LOG_MAX_HISTORY:-14}"/>
    <property name="LOG_TOTAL_SIZE_CAP" value="${LOG_TOTAL_SIZE_CAP:-2GB}"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%-5level app=${APP_NAME} thread=%thread traceId=%X{traceId:-} spanId=%X{spanId:-} node=%X{gatewayNodeId:-} agent=%X{agentId:-} task=%X{taskId:-} correlationId=%X{correlationId:-} logger=%logger{36} msg=%msg%n%ex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="GATEWAY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/gateway.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/gateway.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="com.opensocket.aievent.gateway.netty" level="${GATEWAY_LEVEL}"/>

    <logger name="io.micrometer.tracing" level="${LOG_LEVEL_TRACING}"/>
    <logger name="brave.Tracer" level="${LOG_LEVEL_TRACING}"/>

    <root level="${ROOT_LEVEL}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="GATEWAY_FILE"/>
    </root>
</configuration>
