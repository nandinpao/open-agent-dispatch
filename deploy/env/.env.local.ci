# OpenDispatch P13 local CI environment.
# Values are intentionally local-only and should not be reused for production.

JAVA25_RUNTIME_IMAGE=eclipse-temurin:25-jre
NODE_RUNTIME_IMAGE=node:22-bookworm-slim
POSTGRES_IMAGE=postgres:18-alpine
REDIS_IMAGE=redis:8-alpine
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.156.0
POSTGRES_DB=ai_event_gateway_ci
POSTGRES_USER=ai_event_ci
POSTGRES_PASSWORD=ai_event_ci
POSTGRES_PUBLIC_PORT=15432
REDIS_PUBLIC_PORT=16379
ADAPTER_WORKER_HTTP_PORT=18090
OTEL_COLLECTOR_GRPC_PORT=14317
OTEL_COLLECTOR_HTTP_PORT=14318
OTEL_COLLECTOR_HEALTH_PORT=13133
REDIS_SERVICE_HOST=redis
REDIS_SERVICE_PORT=6379
REDIS_DATABASE=0
FLYWAY_IMAGE=flyway/flyway:11-alpine

CORE_HTTP_PORT=18080
NETTY_ADMIN_HTTP_PORT=18081
NETTY_TCP_PORT=19090
NETTY_WS_PORT=19091
ADMIN_UI_HTTP_PORT=3000
ADMIN_UI_CONTAINER_PORT=3000
ADMIN_UI_HOSTNAME=127.0.0.1

# Optional: set OPENDISPATCH_PUBLIC_HOST=baofire.com when smoke/E2E runs
# from a Docker container and must reach host-exposed ports through a host DNS
# name rather than localhost/127.0.0.1. The smoke scripts will replace
# loopback CORE_URL/NETTY_URL/ADMIN_UI_URL/NETTY_TCP_HOST with this host.
# OPENDISPATCH_PUBLIC_HOST=baofire.com
# OPENDISPATCH_PUBLIC_SCHEME=http
# Prefer this mode for host-routed TCP smoke checks to avoid Bash /dev/tcp
# redirections being killed by host/container security policy.
# SMOKE_TCP_CHECK_MODE=python

CLUSTER_INTERNAL_TOKEN=local-ci-cluster-token-change-me
AGENT_ONBOARDING_TOKEN=local-ci-agent-onboarding-token-change-me
GATEWAY_AGENT_AUTHORIZATION_ENABLED=false
GATEWAY_AGENT_AUTHORIZATION_ALLOW_WHEN_DISABLED=true
# make ci-local is single-Netty and defaults to transport simulator compatibility.
# Set CI_LOCAL_AGENT_AUTH_MODE=core only when explicitly running runtime lifecycle E2E.
CI_LOCAL_AGENT_AUTH_MODE=transport
NETTY_MACHINE_ADMIN_TOKEN=local-ci-netty-machine-token-change-me

CORE_DEFAULT_ROUTING_POLICY=DOMAIN_AWARE
CORE_DEFAULT_TASK_CAPABILITIES=
CORE_PROFILES=local,postgres,redis
NETTY_PROFILES=docker

CORE_URL=http://127.0.0.1:18080
NETTY_URL=http://127.0.0.1:18081
ADMIN_UI_URL=http://127.0.0.1:3000
NETTY_TCP_HOST=127.0.0.1
SMOKE_TIMEOUT_SECONDS=240

# P1-B Micrometer Tracing + OpenTelemetry + OTLP
MANAGEMENT_TRACING_ENABLED=true
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_TRACING_EXPORT_OTLP_ENABLED=true
MANAGEMENT_TRACING_PROPAGATION_CONSUME=w3c,b3
MANAGEMENT_TRACING_PROPAGATION_PRODUCE=w3c
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_TRACES_SCHEDULE_DELAY=1s
MANAGEMENT_OTLP_METRICS_EXPORT_ENABLED=true
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4318/v1/metrics
OTEL_METRICS_EXPORT_STEP=5s
OTEL_SERVICE_NAMESPACE=opendispatch
OTEL_SERVICE_VERSION=local-ci
DEPLOYMENT_ENVIRONMENT=local-ci

NEXT_PUBLIC_APP_NAME="AI Event Gateway Admin"

# P6.11 CI watchdog timing for dispatch/callback regressions.
TASK_LIFECYCLE_TIMEOUT_ENABLED=true
TASK_LIFECYCLE_AUTO_REASSIGN_ENABLED=true
TASK_LIFECYCLE_SCAN_INTERVAL_MS=5000
TASK_LIFECYCLE_CREATED_TIMEOUT=45s
TASK_LIFECYCLE_ASSIGNED_TIMEOUT=45s
TASK_LIFECYCLE_DISPATCHED_TIMEOUT=45s
TASK_LIFECYCLE_RUNNING_TIMEOUT=60s
TASK_LIFECYCLE_MAX_REASSIGNMENTS=5

# P3-B: observable Gateway -> Core HTTP client timeouts.
GATEWAY_CORE_OUTBOUND_CONNECT_TIMEOUT=3s
GATEWAY_CORE_OUTBOUND_REQUEST_TIMEOUT=3s

# P6.13: terminal callbacks wait for Core acceptance before Agent removes durable pending RESULT/ERROR callback.
GATEWAY_CORE_TASK_CALLBACK_RELAY_SYNCHRONOUS_TERMINAL_CALLBACKS=true

# P4-A Core-owned human Admin authentication.
CORE_ADMIN_AUTH_ENABLED=true
CORE_ADMIN_SESSION_TIMEOUT=30m
CORE_ADMIN_SESSION_COOKIE_NAME=OPENDISPATCH_ADMIN_SESSION
CORE_ADMIN_SESSION_COOKIE_SECURE=false
CORE_ADMIN_SESSION_COOKIE_SAME_SITE=lax
CORE_ADMIN_SESSION_REDIS_NAMESPACE=opendispatch:core:admin:sessions:ci
CORE_ADMIN_BOOTSTRAP_USER_ID=ci-admin
CORE_ADMIN_BOOTSTRAP_USERNAME=admin
CORE_ADMIN_BOOTSTRAP_DISPLAY_NAME=OpenDispatch CI Administrator
CORE_ADMIN_BOOTSTRAP_PASSWORD=local-ci-admin-change-me
CORE_ADMIN_BOOTSTRAP_ALLOW_PLAINTEXT_PASSWORD=true
CORE_ADMIN_BOOTSTRAP_PASSWORD_HASH=
CORE_ADMIN_BOOTSTRAP_ROLES=ADMIN
CORE_ADMIN_BOOTSTRAP_ALLOWED_TENANTS=tenant-a
CORE_ADMIN_BOOTSTRAP_DEFAULT_TENANT=tenant-a
CORE_EVENT_INTAKE_INTERNAL_TOKEN=local-ci-event-intake-token-change-me

# CI uses the dedicated ADMIN E2E account from docker-compose.ci.yml.
SMOKE_ADMIN_AUTH_USERNAME=admin-e2e
SMOKE_ADMIN_AUTH_PASSWORD=admin-e2e-password
