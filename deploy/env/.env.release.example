# OpenDispatch release runtime environment.
# Copy to .env.release and replace every REPLACE_WITH_* value before use.
# The release preflight is fail-closed by default and will refuse placeholder secrets.

JAVA25_RUNTIME_IMAGE=eclipse-temurin:25-jre
NODE_RUNTIME_IMAGE=node:22-bookworm-slim
POSTGRES_IMAGE=postgres:18-alpine
REDIS_IMAGE=redis:8-alpine
FLYWAY_IMAGE=flyway/flyway:11-alpine

POSTGRES_DB=ai_event_gateway_release
POSTGRES_USER=ai_event_release
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
POSTGRES_PORT=15432

REDIS_SERVICE_HOST=redis
REDIS_SERVICE_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_PORT=16379

CORE_HTTP_PORT=18080
NETTY_ADMIN_HTTP_PORT=18081
NETTY_TCP_PORT=19090
NETTY_WS_PORT=19091
ADMIN_UI_HTTP_PORT=3000
ADMIN_UI_CONTAINER_PORT=3000
ADMIN_UI_ALLOW_NPM_CI=true
# Set ADMIN_UI_ALLOW_NPM_CI=false when the package was built with --include-admin-runtime-deps and must start offline.

CORE_PROFILES=prod
NETTY_PROFILES=prod
MANAGEMENT_HEALTH_SHOW_DETAILS=never
MANAGEMENT_INFO_ENV_ENABLED=false
CORE_INTERNAL_SECURITY_ENABLED=true
CORE_INTERNAL_PERMIT_ACTUATOR_HEALTH_INFO=false
CORE_INTERNAL_PROTECT_API_MUTATIONS=true
CORE_INTERNAL_ALLOW_LEGACY_TOKEN_HEADER=false
CORE_INTERNAL_SECURITY_AUDIT_LOG_ENABLED=true
CORE_RECOVERY_GOVERNANCE_ENABLED=true
CORE_RECOVERY_GOVERNANCE_REQUIRE_REASON=true
CORE_RECOVERY_GOVERNANCE_MIN_REASON_LENGTH=12
CORE_RECOVERY_GOVERNANCE_REQUIRE_CONFIRMATION=true
CORE_RECOVERY_GOVERNANCE_ALLOW_BODY_OPERATOR_ID_OVERRIDE=false
CORE_RECOVERY_GOVERNANCE_REQUIRE_DUAL_CONTROL_FOR_HIGH_RISK=true
CORE_RECOVERY_GOVERNANCE_FORBID_SELF_APPROVAL=true

GATEWAY_NODE_ID=gateway-node-001
GATEWAY_CORE_FORWARD_ENABLED=true
GATEWAY_CORE_DIRECTORY_SYNC_ENABLED=true
GATEWAY_CORE_TASK_CALLBACK_RELAY_ENABLED=true
GATEWAY_AGENT_AUTHORIZATION_ENABLED=true
GATEWAY_AGENT_AUTHORIZATION_FAIL_CLOSED=true
GATEWAY_AGENT_AUTHORIZATION_ALLOW_WHEN_DISABLED=false
AGENT_AUTH_ENABLED=true
AGENT_WS_HANDSHAKE_AUTH_ENABLED=true
NETTY_MACHINE_AUTH_ENABLED=true
NETTY_MACHINE_WS_HANDSHAKE_AUTH_ENABLED=true

# Role-separated internal tokens. Do not reuse the same value across roles.
CLUSTER_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CLUSTER_INTERNAL_TOKEN
CORE_GATEWAY_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_GATEWAY_TOKEN
CORE_ADAPTER_WORKER_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_ADAPTER_WORKER_TOKEN
CORE_OPERATOR_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_OPERATOR_TOKEN
CORE_RECOVERY_OPERATOR_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_RECOVERY_OPERATOR_TOKEN
CORE_RECOVERY_ADMIN_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_RECOVERY_ADMIN_TOKEN
CORE_RECOVERY_APPROVER_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_RECOVERY_APPROVER_TOKEN
CORE_ACTUATOR_INTERNAL_TOKEN=REPLACE_WITH_STRONG_CORE_ACTUATOR_TOKEN
GATEWAY_CORE_FORWARD_AUTH_TOKEN=REPLACE_WITH_STRONG_CORE_GATEWAY_TOKEN
GATEWAY_CORE_DIRECTORY_SYNC_AUTH_TOKEN=REPLACE_WITH_STRONG_CORE_GATEWAY_TOKEN
GATEWAY_CORE_TASK_CALLBACK_RELAY_AUTH_TOKEN=REPLACE_WITH_STRONG_CORE_GATEWAY_TOKEN
GATEWAY_AGENT_AUTHORIZATION_AUTH_TOKEN=REPLACE_WITH_STRONG_CORE_GATEWAY_TOKEN
AGENT_ONBOARDING_TOKEN=REPLACE_WITH_STRONG_AGENT_ONBOARDING_TOKEN
NETTY_MACHINE_ADMIN_TOKEN=REPLACE_WITH_STRONG_NETTY_MACHINE_ADMIN_TOKEN

CORE_DEFAULT_ROUTING_POLICY=DOMAIN_AWARE
CORE_REMEDIATION_WORKFLOW_METRICS_ENABLED=true

NEXT_PUBLIC_APP_NAME="AI Event Gateway Admin"
NEXT_PUBLIC_ADMIN_BACKEND_MODE=dual
NEXT_PUBLIC_USE_MOCK=false
ADMIN_UI_SECURITY_PROFILE=prod
ADMIN_UI_FAIL_CLOSED=true
ADMIN_UI_COOKIE_SECURE=true
NEXT_PUBLIC_AUTH_ENABLED=true
CORE_FORWARD_BROWSER_AUTHORIZATION=false
NEXT_PUBLIC_CORE_API_BASE_URL=/core-api
NEXT_PUBLIC_NETTY_API_BASE_URL=/netty-api
NEXT_PUBLIC_GATEWAY_API_BASE_URL=/netty-api

# Optional Issue Tracking / Redmine integration.
# Keep API keys in .env.release only; Admin UI displays configured/not-configured, not the secret value.
ISSUE_ACTION_ENABLED=false
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=false
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=false
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=false
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS
ISSUE_EXECUTOR_DEFAULT_VENDOR=REDMINE
REDMINE_EXECUTOR_ENABLED=false
REDMINE_EXECUTOR_BASE_URL=REPLACE_WITH_REDMINE_BASE_URL
REDMINE_EXECUTOR_API_KEY=REPLACE_WITH_REDMINE_API_KEY
REDMINE_EXECUTOR_PROJECT_ID=REPLACE_WITH_REDMINE_PROJECT_IDENTIFIER_OR_ID
REDMINE_EXECUTOR_TRACKER_ID=1
REDMINE_EXECUTOR_NAME=redmine-issue-executor
REDMINE_EXECUTOR_ISSUE_URL_TEMPLATE=REPLACE_WITH_REDMINE_ISSUE_URL_TEMPLATE
REDMINE_EXECUTOR_PRIORITY_CRITICAL=REPLACE_WITH_REDMINE_CRITICAL_PRIORITY_NAME_OR_ID
REDMINE_EXECUTOR_PRIORITY_HIGH=REPLACE_WITH_REDMINE_HIGH_PRIORITY_NAME_OR_ID
REDMINE_EXECUTOR_PRIORITY_MEDIUM=REPLACE_WITH_REDMINE_MEDIUM_PRIORITY_NAME_OR_ID
REDMINE_EXECUTOR_PRIORITY_LOW=REPLACE_WITH_REDMINE_LOW_PRIORITY_NAME_OR_ID

# P3-B: observable Gateway -> Core HTTP client timeouts.
GATEWAY_CORE_OUTBOUND_CONNECT_TIMEOUT=3s
GATEWAY_CORE_OUTBOUND_REQUEST_TIMEOUT=3s

# P6.13: terminal callbacks wait for Core acceptance before Agent removes durable pending RESULT/ERROR callback.
GATEWAY_CORE_TASK_CALLBACK_RELAY_SYNCHRONOUS_TERMINAL_CALLBACKS=true

# P4-A Core-owned human Admin authentication. Generate a DelegatingPasswordEncoder hash, e.g. {bcrypt}...
CORE_ADMIN_AUTH_ENABLED=true
CORE_ADMIN_SESSION_TIMEOUT=30m
CORE_ADMIN_SESSION_COOKIE_NAME=OPENDISPATCH_ADMIN_SESSION
CORE_ADMIN_SESSION_COOKIE_SECURE=true
CORE_ADMIN_SESSION_COOKIE_SAME_SITE=lax
CORE_ADMIN_SESSION_REDIS_NAMESPACE=opendispatch:core:admin:sessions
CORE_ADMIN_BOOTSTRAP_USER_ID=admin
CORE_ADMIN_BOOTSTRAP_USERNAME=admin
CORE_ADMIN_BOOTSTRAP_DISPLAY_NAME=OpenDispatch Administrator
CORE_ADMIN_BOOTSTRAP_PASSWORD=
CORE_ADMIN_BOOTSTRAP_ALLOW_PLAINTEXT_PASSWORD=false
CORE_ADMIN_BOOTSTRAP_PASSWORD_HASH=REPLACE_WITH_DELEGATING_PASSWORD_HASH
CORE_ADMIN_BOOTSTRAP_ROLES=ADMIN
CORE_ADMIN_BOOTSTRAP_ALLOWED_TENANTS=REPLACE_WITH_TENANT_ID
CORE_ADMIN_BOOTSTRAP_DEFAULT_TENANT=REPLACE_WITH_TENANT_ID
CORE_EVENT_INTAKE_INTERNAL_TOKEN=REPLACE_WITH_STRONG_EVENT_INTAKE_TOKEN

# P5-A production observability is deployed with a second fail-closed env file and Compose overlay.
# Copy deploy/env/.env.observability.release.example to deploy/env/.env.observability.release,
# generate PKI and bearer secrets with bin/generate-otel-pki.sh, then run the base and overlay together.
# Never place Collector private keys or bearer tokens in this base application env file.
