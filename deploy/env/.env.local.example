# OpenDispatch local integrated stack
# Copy to deploy/env/.env.local when you need local secrets/overrides.

COMPOSE_PROJECT_NAME=opendispatch
JAVA25_RUNTIME_IMAGE=eclipse-temurin:25-jre
NODE_RUNTIME_IMAGE=node:22-bookworm-slim
POSTGRES_IMAGE=postgres:18-alpine
REDIS_IMAGE=redis:8-alpine
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.156.0
REDIS_SERVICE_HOST=redis
REDIS_SERVICE_PORT=6379
REDIS_DATABASE=0

POSTGRES_DB=ai_event_gateway
POSTGRES_USER=ai_event
POSTGRES_PASSWORD=ai_event

CLUSTER_INTERNAL_TOKEN=local-cluster-token-change-me
AGENT_ONBOARDING_TOKEN=local-agent-onboarding-token-change-me
# Local integrated mode validates Agent credentials against Core.
CORE_INTERNAL_SECURITY_ENABLED=true
CORE_INTERNAL_PROTECT_API_MUTATIONS=false
GATEWAY_AGENT_AUTHORIZATION_ENABLED=true
GATEWAY_AGENT_AUTHORIZATION_ALLOW_WHEN_DISABLED=false
CORE_BOOTSTRAP_ADMIN_AUTH_MODE=SESSION
CORE_BOOTSTRAP_ENV_FILE=deploy/env/.env.local
CI_LOCAL_AGENT_AUTH_MODE=transport
NETTY_MACHINE_ADMIN_TOKEN=local-netty-machine-token-change-me

# Local Admin UI may be opened through any development hostname on port 3000.
# Production remains strict and must provide explicit origins.
ADMIN_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_CORS_ALLOWED_ORIGIN_PATTERNS=http://*:[3000],https://*:[3000]

CORE_HTTP_PORT=18080
NETTY_ADMIN_HTTP_PORT=18081
NETTY_TCP_PORT=19090
NETTY_WS_PORT=19091
ADMIN_UI_HTTP_PORT=3000
ADMIN_UI_CONTAINER_PORT=3000
ADMIN_UI_HOSTNAME=127.0.0.1
POSTGRES_PUBLIC_PORT=15432
REDIS_PUBLIC_PORT=16379
ADAPTER_WORKER_HTTP_PORT=18090
OTEL_COLLECTOR_GRPC_PORT=14317
OTEL_COLLECTOR_HTTP_PORT=14318
OTEL_COLLECTOR_HEALTH_PORT=13133

NEXT_PUBLIC_APP_NAME="AI Event Gateway Admin"
NEXT_PUBLIC_ADMIN_BACKEND_MODE=dual
NEXT_PUBLIC_USE_MOCK=false
ADMIN_UI_COOKIE_SECURE=false
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_CORE_API_BASE_URL=/core-api
NEXT_PUBLIC_NETTY_API_BASE_URL=/netty-api
NEXT_PUBLIC_GATEWAY_API_BASE_URL=/netty-api
NEXT_PUBLIC_NETTY_RUNTIME_WS_URL=/api/admin/runtime/stream
NEXT_PUBLIC_GATEWAY_WS_URL=/api/admin/runtime/stream
NEXT_PUBLIC_REFRESH_INTERVAL_MS=5000
NEXT_PUBLIC_REQUEST_TIMEOUT_MS=10000
NEXT_PUBLIC_API_CONTRACT_MODE=warn

# P3 domain-aware routing default
CORE_DEFAULT_ROUTING_POLICY=DOMAIN_AWARE

# Issue Tracking / Redmine local integration
# These values are consumed by deploy/docker-compose.local.yml and exposed only to the Core service.
ISSUE_ACTION_ENABLED=true
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=true
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=true
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=true
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS
ISSUE_EXECUTOR_DEFAULT_VENDOR=REDMINE
REDMINE_EXECUTOR_ENABLED=true
REDMINE_EXECUTOR_BASE_URL=http://baofire.com:8700
REDMINE_EXECUTOR_API_KEY=0d01594c9854b5cd2a6562e699e3514f4555cdb3
REDMINE_EXECUTOR_PROJECT_ID=redmine
REDMINE_EXECUTOR_TRACKER_ID=3
REDMINE_EXECUTOR_NAME=redmine-issue-executor
REDMINE_EXECUTOR_ISSUE_URL_TEMPLATE=http://baofire.com:8700/issues/{issueId}
REDMINE_EXECUTOR_PRIORITY_CRITICAL=CRITICAL
REDMINE_EXECUTOR_PRIORITY_HIGH=HIGH
REDMINE_EXECUTOR_PRIORITY_MEDIUM=MIDDLE
REDMINE_EXECUTOR_PRIORITY_LOW=LOW

# Host path where docker-compose bind-mounts Core/Netty/Admin UI file logs for uploadable diagnostics.
OPENDISPATCH_LOG_ROOT=../.local/opendispatch-logs

# R11 Logback / dispatch trace logging
# LOG_DIR is mounted inside Core/Netty containers. Use docker logs for console output and this
# directory for rolling file diagnostics when investigating intake/routing/A2A issues.
LOG_DIR=/logs
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_CORE=INFO
LOG_LEVEL_GATEWAY=DEBUG
LOG_LEVEL_DISPATCH_TRACE=DEBUG
# P6.3 keeps dispatch diagnostics at DEBUG in local so uploaded logs include Flow Rule lookup counts.
LOG_MAX_FILE_SIZE=50MB
LOG_MAX_HISTORY=14
LOG_TOTAL_SIZE_CAP=2GB

# P1-B Micrometer Tracing + OpenTelemetry + OTLP
# Consume W3C and legacy single-header B3 during migration; produce W3C only.
MANAGEMENT_TRACING_ENABLED=true
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
MANAGEMENT_TRACING_EXPORT_OTLP_ENABLED=true
MANAGEMENT_TRACING_PROPAGATION_CONSUME=w3c,b3
MANAGEMENT_TRACING_PROPAGATION_PRODUCE=w3c
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_TRACES_SCHEDULE_DELAY=1s
MANAGEMENT_OTLP_METRICS_EXPORT_ENABLED=true
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4318/v1/metrics
OTEL_METRICS_EXPORT_STEP=5s
OTEL_SERVICE_NAMESPACE=opendispatch
OTEL_SERVICE_VERSION=local-dev
DEPLOYMENT_ENVIRONMENT=local
LOG_LEVEL_TRACING=INFO


# Stage 8 local release-gate delivery path
# Keep local/CI strict evidence on the implemented direct assignment -> dispatch request -> Netty -> Agent callback path.

# P6.11 local lifecycle watchdog tuning. These are intentionally short for local/SIT
# so DISPATCHED/RUNNING tasks without terminal callback are automatically reassigned
# without waiting the production defaults of 10-30 minutes.
TASK_LIFECYCLE_TIMEOUT_ENABLED=true
TASK_LIFECYCLE_AUTO_REASSIGN_ENABLED=true
TASK_LIFECYCLE_SCAN_INTERVAL_MS=5000
TASK_LIFECYCLE_CREATED_TIMEOUT=45s
TASK_LIFECYCLE_ASSIGNED_TIMEOUT=45s
TASK_LIFECYCLE_DISPATCHED_TIMEOUT=45s
TASK_LIFECYCLE_RUNNING_TIMEOUT=60s
TASK_LIFECYCLE_MAX_REASSIGNMENTS=5

# P3-B: observable Gateway -> Core HTTP client timeouts.
GATEWAY_CORE_OUTBOUND_CONNECT_TIMEOUT=3s
GATEWAY_CORE_OUTBOUND_REQUEST_TIMEOUT=3s

# P6.13: terminal callbacks wait for Core acceptance before Agent removes durable pending RESULT/ERROR callback.
GATEWAY_CORE_TASK_CALLBACK_RELAY_SYNCHRONOUS_TERMINAL_CALLBACKS=true

# P4-A Core-owned human Admin authentication (Admin UI switches in P4-B).
CORE_ADMIN_AUTH_ENABLED=true
CORE_ADMIN_SESSION_TIMEOUT=30m
CORE_ADMIN_SESSION_COOKIE_NAME=OPENDISPATCH_ADMIN_SESSION
CORE_ADMIN_SESSION_COOKIE_SECURE=false
CORE_ADMIN_SESSION_COOKIE_SAME_SITE=lax
CORE_ADMIN_SESSION_REDIS_NAMESPACE=opendispatch:core:admin:sessions
CORE_ADMIN_BOOTSTRAP_USER_ID=admin
CORE_ADMIN_BOOTSTRAP_USERNAME=admin
CORE_ADMIN_BOOTSTRAP_DISPLAY_NAME=OpenDispatch Administrator
CORE_ADMIN_BOOTSTRAP_PASSWORD=local-admin-change-me
CORE_ADMIN_BOOTSTRAP_ALLOW_PLAINTEXT_PASSWORD=true
CORE_ADMIN_BOOTSTRAP_PASSWORD_HASH=
CORE_ADMIN_BOOTSTRAP_ROLES=ADMIN
CORE_ADMIN_BOOTSTRAP_ALLOWED_TENANTS=tenant-a
CORE_ADMIN_BOOTSTRAP_DEFAULT_TENANT=tenant-a
CORE_ADMIN_BOOTSTRAP_ENABLED=true
# E2E role accounts are disabled for normal local use. Enable them only for dedicated auth E2E.
CORE_ADMIN_E2E_ADMIN_ENABLED=false
CORE_ADMIN_E2E_OPERATOR_ENABLED=false
CORE_ADMIN_E2E_VIEWER_ENABLED=false
CORE_EVENT_INTAKE_INTERNAL_TOKEN=local-event-intake-token-change-me

# Local CD credential smoke. Keep aligned with the normal local bootstrap administrator above.
SMOKE_ADMIN_AUTH_USERNAME=admin
SMOKE_ADMIN_AUTH_PASSWORD=local-admin-change-me

# Admin UI server-side Core connectivity. The UI first uses the internal Compose
# service name and falls back to the Docker host route when it is started in a
# separate network or as a standalone container.
CORE_BACKEND_FALLBACK_ORIGINS=http://host.docker.internal:18080
ADMIN_UI_BACKEND_CONNECT_TIMEOUT_MS=2500
ADMIN_UI_CORE_STARTUP_TIMEOUT_MS=120000
