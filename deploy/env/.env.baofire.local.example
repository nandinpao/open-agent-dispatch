# Host-routed local CI example for running smoke/E2E from a Docker container
# that cannot reach services through localhost/127.0.0.1.
#
# Copy the values you need into deploy/env/.env.local.ci or export them before
# running make ci-release. Keep secrets in your private .env; this file is safe
# as a template only.

# The public host name that resolves from test containers to the Docker host.
OPENDISPATCH_PUBLIC_HOST=baofire.com
OPENDISPATCH_PUBLIC_SCHEME=http

# These explicit URLs are optional. When OPENDISPATCH_PUBLIC_HOST is set,
# scripts/ci/local-smoke.sh and scripts/acceptance/runtime-lifecycle-e2e.sh
# replace loopback defaults with these host-routed endpoints automatically.
CORE_URL=http://baofire.com:18080
NETTY_URL=http://baofire.com:18081
ADMIN_UI_URL=http://baofire.com:3000
NETTY_TCP_HOST=baofire.com

# Prefer Python socket probing for host-routed TCP smoke checks. This avoids
# repeated Bash /dev/tcp redirections, which can be killed by some host/container
# security policies when targeting public hostnames.
SMOKE_TCP_CHECK_MODE=python

# Keep browser-facing Admin UI APIs same-origin through the Next.js proxy.
# Do not point these NEXT_PUBLIC values at localhost from inside container-based tests.
NEXT_PUBLIC_CORE_API_BASE_URL=/core-api
NEXT_PUBLIC_NETTY_API_BASE_URL=/netty-api
NEXT_PUBLIC_GATEWAY_API_BASE_URL=/netty-api
NEXT_PUBLIC_GATEWAY_WS_URL=/api/admin/runtime/stream

# Allow the browser host origin when Admin UI is opened through baofire.com.
ADMIN_UI_PUBLIC_ORIGIN=http://baofire.com:3000
EXTRA_ADMIN_CORS_ALLOWED_ORIGINS=http://baofire.com:3000
ADMIN_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://baofire.com:3000
ADMIN_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:[3000],http://127.0.0.1:[3000],http://baofire.com:[3000]

# Netty must call Core authorization for governed Agent long-connections.
GATEWAY_AGENT_AUTHORIZATION_ENABLED=false
GATEWAY_AGENT_AUTHORIZATION_ALLOW_WHEN_DISABLED=true
CI_LOCAL_AGENT_AUTH_MODE=transport

# Issue Tracking / Redmine local integration
# These values are consumed by deploy/docker-compose.local.yml and exposed only to the Core service.
ISSUE_ACTION_ENABLED=true
ISSUE_ACTION_CREATE_ON_COMPLETED_TASK=true
ISSUE_ACTION_CREATE_ON_FAILED_TASK=true
ISSUE_ACTION_UPDATE_EXISTING_ISSUE_COMMENT=true
ADAPTER_EXECUTOR_MODE=embedded
ADAPTER_EXECUTOR_ENABLED=true
ADAPTER_EXECUTOR_AUTO_EXECUTE_PENDING=true
ADAPTER_EXECUTOR_AUDIT_STORE=MYBATIS
ISSUE_EXECUTOR_DEFAULT_VENDOR=REDMINE
REDMINE_EXECUTOR_ENABLED=true
REDMINE_EXECUTOR_BASE_URL=http://baofire.com:8700
REDMINE_EXECUTOR_API_KEY=REPLACE_WITH_REDMINE_API_KEY
REDMINE_EXECUTOR_PROJECT_ID=redmine
REDMINE_EXECUTOR_TRACKER_ID=3
REDMINE_EXECUTOR_NAME=redmine-issue-executor
REDMINE_EXECUTOR_ISSUE_URL_TEMPLATE=http://baofire.com:8700/issues/{issueId}
REDMINE_EXECUTOR_PRIORITY_CRITICAL=CRITICAL
REDMINE_EXECUTOR_PRIORITY_HIGH=HIGH
REDMINE_EXECUTOR_PRIORITY_MEDIUM=MIDDLE
REDMINE_EXECUTOR_PRIORITY_LOW=LOW

# Admin UI BFF fallback when its container cannot resolve/reach the internal
# Compose service name `core`. The browser still uses same-origin /api/auth.
CORE_BACKEND_FALLBACK_ORIGINS=http://baofire.com:18080,http://host.docker.internal:18080
ADMIN_UI_BACKEND_CONNECT_TIMEOUT_MS=2500
ADMIN_UI_CORE_STARTUP_TIMEOUT_MS=120000
