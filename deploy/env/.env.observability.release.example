# P5-A production observability overlay.
# Copy to .env.observability.release and replace every REPLACE_WITH_* value.
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.156.0
OTEL_HAPROXY_IMAGE=haproxy:3.2-alpine
OTEL_SECRET_DIR=REPLACE_WITH_ABSOLUTE_OBSERVABILITY_SECRET_DIRECTORY
OTEL_INGEST_TOKEN=REPLACE_WITH_TOKEN_FROM_ingest.tokens
OTEL_BACKEND_TRACES_ENDPOINT=REPLACE_WITH_OTLP_GRPC_TRACE_BACKEND_HOST_PORT
OTEL_BACKEND_METRICS_ENDPOINT=REPLACE_WITH_PROMETHEUS_REMOTE_WRITE_HTTPS_URL
OTEL_BACKEND_LOGS_ENDPOINT=REPLACE_WITH_OTLP_GRPC_LOG_BACKEND_HOST_PORT
OTEL_SERVICE_NAMESPACE=opendispatch
OTEL_SERVICE_VERSION=release
OTEL_TRACES_SAMPLING_PROBABILITY=1.0
OTEL_COLLECTOR_GRPC_PORT=14317
OTEL_COLLECTOR_HTTP_PORT=14318
OTEL_HAPROXY_STATS_PORT=18404
OTEL_GATEWAY_METRICS_A_PORT=18888
OTEL_GATEWAY_METRICS_B_PORT=18889
OTEL_SAMPLER_METRICS_A_PORT=18890
OTEL_SAMPLER_METRICS_B_PORT=18891
